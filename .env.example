DATABASE_URL=postgresql://postgres:password@localhost:5432/trustoms
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
JWT_SECRET=your-jwt-secret
REDIS_URL=redis://localhost:6379
NODE_ENV=development
PORT=5000

# ─── Platform Feature Service (PS-WMS shared) ─────────────────────────────────
# Cloud Run URL of the shared Platform Feature Service.
# Leave unset in local dev — routes degrade gracefully when not configured.
PLATFORM_FEATURE_SERVICE_URL=
# API key scoped to app_id 'trustoms' (issued by the platform team).
PLATFORM_FEATURE_API_KEY=

# ─── Platform Intelligence Service (PS-WMS shared) ────────────────────────────
# Cloud Run URL of the shared Platform Intelligence Service.
# Leave unset in local dev — AI Copilot and briefing routes degrade gracefully.
PLATFORM_INTELLIGENCE_SERVICE_URL=
# API key scoped to app_id 'trustoms' (issued by the platform team).
PLATFORM_INTELLIGENCE_API_KEY=
